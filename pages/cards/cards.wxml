<!--pages/cards/cards.wxml-->
<view class="page">
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 套装区域 -->
    <view class="section" wx:if="{{sets.length > 0}}">
      <view class="section-title">卡牌套装</view>
      <view class="sets-list">
        <view
          class="set-item {{item.completed ? 'set-completed' : ''}} {{expandedSetId === item.setId ? 'set-expanded' : ''}}"
          wx:for="{{sets}}"
          wx:key="setId"
          bindtap="onToggleSet"
          data-setid="{{item.setId}}"
        >
          <view class="set-header">
            <view class="set-name">{{item.setName}}</view>
            <view class="set-right">
              <text class="set-progress">{{item.progress}}</text>
              <text wx:if="{{item.completed}}" class="set-check">✓</text>
            </view>
          </view>
          <view class="set-effect">{{item.effectDescription}}</view>
        </view>
      </view>
    </view>

    <!-- 展开的卡组卡牌 -->
    <view class="section" wx:if="{{expandedSetId !== -999}}">
      <view class="section-title-row">
        <text class="section-title">卡组详情</text>
        <text class="show-all-btn" bindtap="onShowAll">查看全部</text>
      </view>
      <view class="card-grid">
        <block wx:for="{{allCards}}" wx:key="id">
          <view
            wx:if="{{item.card_set_id === expandedSetId}}"
            class="game-card {{item.owned ? '' : 'card-unowned'}}"
            style="background: {{item.owned ? item.setBg : '#f5f5f5'}}; border-color: {{item.owned ? item.setHue : '#e0e0e0'}};"
          >
            <view class="card-new-dot" wx:if="{{item.isNew}}"></view>
            <view class="game-card-set-label" style="background: {{item.owned ? item.setBg : '#f5f5f5'}}; border-color: {{item.owned ? item.setHue : '#e0e0e0'}};">
              <text style="color: {{item.owned ? item.setHue : '#bbb'}};">{{item.setName}}</text>
            </view>
            <view class="game-card-name {{item.owned ? '' : 'text-gray'}}">{{item.card_name}}</view>
            <view class="game-card-stars stars-{{item.owned ? item.starsCount : 0}}">{{item.stars}}</view>
            <view class="game-card-owned {{item.owned ? '' : 'text-gray'}}">x{{item.owned_count}}</view>
          </view>
        </block>
      </view>
    </view>

    <!-- 全部卡牌列表 -->
    <view class="section" wx:if="{{expandedSetId === -999}}">
      <view class="section-title">全部卡牌</view>
      <view class="card-grid">
        <view
          wx:for="{{allCards}}"
          wx:key="id"
          class="game-card {{item.owned ? '' : 'card-unowned'}}"
          style="background: {{item.owned ? item.setBg : '#f5f5f5'}}; border-color: {{item.owned ? item.setHue : '#e0e0e0'}};"
        >
          <view class="card-new-dot" wx:if="{{item.isNew}}"></view>
          <view class="game-card-set-label" style="background: {{item.owned ? item.setBg : '#f5f5f5'}}; border-color: {{item.owned ? item.setHue : '#e0e0e0'}};">
            <text style="color: {{item.owned ? item.setHue : '#bbb'}};">{{item.setName}}</text>
          </view>
          <view class="game-card-name {{item.owned ? '' : 'text-gray'}}">{{item.card_name}}</view>
          <view class="game-card-stars stars-{{item.owned ? item.starsCount : 0}}">{{item.stars}}</view>
          <view class="game-card-owned {{item.owned ? '' : 'text-gray'}}">x{{item.owned_count}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
