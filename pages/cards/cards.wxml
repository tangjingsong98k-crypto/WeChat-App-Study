<!--pages/cards/cards.wxml-->
<view class="page">
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 套装区域 -->
    <view class="section" wx:if="{{sets.length > 0}}">
      <view class="section-title">卡牌套装</view>
      <view class="sets-list">
        <view class="set-item {{item.completed ? 'set-completed' : ''}}" wx:for="{{sets}}" wx:key="setId">
          <view class="set-header">
            <view class="set-name">{{item.setName}}</view>
            <view class="set-status">
              <text wx:if="{{item.completed}}" class="set-check">✓ 已完成</text>
              <text wx:else class="set-incomplete">未完成</text>
            </view>
          </view>
          <view class="set-effect">{{item.effectDescription}}</view>
        </view>
      </view>
    </view>

    <!-- 卡牌列表区域 -->
    <view class="section">
      <view class="section-title">我的卡牌</view>
      <view class="empty-tip" wx:if="{{cards.length === 0}}">
        <text>暂无卡牌，浇水时有机会获得哦~</text>
      </view>
      <view class="card-grid" wx:else>
        <view class="game-card set-{{item.card_set_id}}" wx:for="{{cards}}" wx:key="card_id" style="background: {{item.setBg}}; border-color: {{item.setHue}};">
          <!-- 卡组名称：顶部居中小字，带衬线遮挡效果 -->
          <view class="game-card-set-label" style="background: {{item.setBg}}; border-color: {{item.setHue}};">
            <text style="color: {{item.setHue}};">{{item.setName}}</text>
          </view>
          <!-- 卡牌名称：居中 -->
          <view class="game-card-name">{{item.card_name}}</view>
          <!-- 稀有度星星：居中在名称下方 -->
          <view class="game-card-stars stars-{{item.starsCount}}">{{item.stars}}</view>
          <!-- 拥有数量 -->
          <view class="game-card-count">×{{item.owned_count}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
