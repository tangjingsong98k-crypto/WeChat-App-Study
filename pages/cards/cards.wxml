<!--pages/cards/cards.wxml-->
<view class="page">
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 套装区域 -->
    <view class="section" wx:if="{{sets.length > 0}}">
      <view class="section-title">卡牌套装</view>
      <view class="sets-list">
        <view class="set-item {{item.completed ? 'set-completed' : ''}}" wx:for="{{sets}}" wx:key="setId">
          <view class="set-header">
            <view class="set-name">{{item.setName}}</view>
            <view class="set-status">
              <text wx:if="{{item.completed}}" class="set-check">✓ 已完成</text>
              <text wx:else class="set-incomplete">未完成</text>
            </view>
          </view>
          <view class="set-effect">{{item.effectDescription}}</view>
        </view>
      </view>
    </view>

    <!-- 卡牌列表区域 -->
    <view class="section">
      <view class="section-title">我的卡牌</view>
      <view class="empty-tip" wx:if="{{cards.length === 0}}">
        <text>暂无卡牌，浇水时有机会获得哦~</text>
      </view>
      <view class="card-grid" wx:else>
        <view class="card-item quality-{{item.card_quality}}" wx:for="{{cards}}" wx:key="card_id">
          <view class="card-icon">{{item.card_icon}}</view>
          <view class="card-name">{{item.card_name}}</view>
          <view class="card-quality-tag">{{item.card_quality === 'common' ? '普通' : item.card_quality === 'rare' ? '稀有' : item.card_quality === 'epic' ? '史诗' : '传说'}}</view>
          <view class="card-count">×{{item.owned_count}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
