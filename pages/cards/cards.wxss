/* pages/cards/cards.wxss */
.page {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #f3e5f5 0%, #ffffff 100%);
  box-sizing: border-box;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #7b1fa2;
}

.sets-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.set-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e0e0e0;
}

.set-item.set-completed {
  border-color: #4caf50;
  background: #f1f8e9;
}

.set-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.set-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.set-check {
  font-size: 24rpx;
  color: #4caf50;
  font-weight: bold;
}

.set-incomplete {
  font-size: 24rpx;
  color: #999;
}

.set-effect {
  font-size: 26rpx;
  color: #666;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.card-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e0e0e0;
  position: relative;
}

.card-item.quality-common {
  border-color: #bdbdbd;
}

.card-item.quality-rare {
  border-color: #42a5f5;
  background: linear-gradient(180deg, #e3f2fd 0%, #ffffff 100%);
}

.card-item.quality-epic {
  border-color: #ab47bc;
  background: linear-gradient(180deg, #f3e5f5 0%, #ffffff 100%);
}

.card-item.quality-legendary {
  border-color: #ffa726;
  background: linear-gradient(180deg, #fff3e0 0%, #ffffff 100%);
}

.card-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
  margin-bottom: 8rpx;
}

.card-quality-tag {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.quality-rare .card-quality-tag {
  color: #1976d2;
}

.quality-epic .card-quality-tag {
  color: #7b1fa2;
}

.quality-legendary .card-quality-tag {
  color: #e65100;
}

.card-count {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
}
