/* pages/cards/cards.wxss */
.page {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #f3e5f5 0%, #ffffff 100%);
  box-sizing: border-box;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #7b1fa2;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-row .section-title {
  margin-bottom: 0;
}

.show-all-btn {
  font-size: 26rpx;
  color: #7b1fa2;
  font-weight: bold;
}

/* 套装列表 */
.sets-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.set-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e0e0e0;
}

.set-item.set-completed {
  border-color: #4caf50;
  background: #f1f8e9;
}

.set-item.set-expanded {
  border-color: #7b1fa2;
  box-shadow: 0 4rpx 16rpx rgba(123, 31, 162, 0.15);
}

.set-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.set-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.set-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.set-progress {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
}

.set-check {
  font-size: 26rpx;
  color: #4caf50;
  font-weight: bold;
}

.set-effect {
  font-size: 26rpx;
  color: #666;
}

.set-completed .set-effect {
  color: #2e7d32;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* ========== 卡牌网格 ========== */
.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

/* ========== 游戏卡牌 UI ========== */
.game-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 12rpx 24rpx;
  border-radius: 16rpx;
  border: 3rpx solid #ccc;
  min-height: 200rpx;
  overflow: hidden;
}

/* 未拥有的卡牌 */
.game-card.card-unowned {
  opacity: 0.7;
}

.text-gray {
  color: #bbb !important;
}

/* 卡组名称标签 */
.game-card-set-label {
  position: absolute;
  top: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 2rpx 14rpx;
  border: 2rpx solid #ccc;
  border-top: none;
  border-radius: 0 0 10rpx 10rpx;
  font-size: 18rpx;
  white-space: nowrap;
  z-index: 2;
}

/* 卡牌名称 */
.game-card-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 8rpx;
}

/* 稀有度星星 */
.game-card-stars {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.game-card-stars.stars-1 { color: #9e9e9e; }
.game-card-stars.stars-2 { color: #42a5f5; }
.game-card-stars.stars-3 { color: #ab47bc; }
.game-card-stars.stars-5 { color: #ffa000; }
.game-card-stars.stars-0 { color: #ddd; }

/* 拥有数量：右下角 */
.game-card-owned {
  position: absolute;
  bottom: 8rpx;
  right: 12rpx;
  font-size: 22rpx;
  color: #555;
  font-weight: bold;
}

/* ========== 新卡牌红点 ========== */
.card-new-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #f44336;
  border-radius: 50%;
  z-index: 10;
}
