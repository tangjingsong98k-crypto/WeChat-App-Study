/* pages/dev-panel/dev-panel.wxss */
.page {
  min-height: 100vh;
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #263238 0%, #37474f 100%);
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  margin-top: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #4fc3f7;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #90a4ae;
}

/* 输入区域 */
.input-area {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.id-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.id-input::placeholder {
  color: #78909c;
}

.history-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: rgba(79, 195, 247, 0.2);
  border: 2rpx solid #4fc3f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  padding: 0;
  margin: 0;
  line-height: 80rpx;
}

.history-btn::after {
  border: none;
}

.enter-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4fc3f7, #0288d1);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.enter-btn::after {
  border: none;
}

.enter-btn[disabled] {
  background: #546e7a;
  color: #90a4ae;
}

/* 历史面板 */
.history-panel {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  max-height: 600rpx;
  overflow-y: auto;
}

.history-title {
  font-size: 28rpx;
  color: #4fc3f7;
  font-weight: bold;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.history-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #78909c;
  font-size: 26rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.history-item:active {
  background: rgba(79, 195, 247, 0.15);
}

.history-item-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.history-id {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  font-family: monospace;
}

.history-species {
  font-size: 24rpx;
  color: #90a4ae;
}

.history-item-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.history-level {
  font-size: 26rpx;
  color: #4fc3f7;
  font-weight: bold;
}

.history-grow {
  font-size: 22rpx;
  color: #78909c;
}

/* 提示 */
.tips {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #607d8b;
}
