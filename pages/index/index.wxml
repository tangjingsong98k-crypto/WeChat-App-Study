<!--pages/index/index.wxml-->
<view class="page-container" wx:if="{{!loading}}">
  <!-- 树展示区域 -->
  <view class="tree-area">
    <view class="tree-icon">{{speciesIcon}}</view>
    <view class="tree-info">
      <text class="tree-name">{{speciesName}}</text>
      <text class="tree-level">Lv.{{level}}</text>
    </view>
  </view>

  <!-- 属性进度条 -->
  <view class="stats-area">
    <view class="stat-item">
      <view class="stat-label">
        <text class="stat-icon">🌱</text>
        <text>成长值</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill grow" style="width: {{growPercent}}%"></view>
      </view>
      <text class="stat-value">{{growScore}}</text>
    </view>

    <view class="stat-item">
      <view class="stat-label">
        <text class="stat-icon">❤️</text>
        <text>健康值</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill health" style="width: {{healthScore}}%"></view>
      </view>
      <text class="stat-value">{{healthScore}}/100</text>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-area">
    <view class="action-btn-wrapper">
      <!-- 浇水飘字动画 -->
      <view class="water-float" wx:for="{{waterFloats}}" wx:key="id">
        <text class="water-float-text">{{item.text}}</text>
      </view>

      <button
        class="action-btn water-btn {{waterCount <= 0 ? 'disabled' : ''}}"
        disabled="{{waterCount <= 0}}"
        bindtap="onWater"
        bindlongpress="onWaterLongPressStart"
        bindtouchend="onWaterLongPressEnd"
      >
        <text class="btn-icon">💧</text>
        <text class="btn-text">浇水</text>
      </button>
      <view class="count-display">{{waterCount}}/{{maxWaterCount}}</view>
      <view class="countdown" wx:if="{{countdown}}">
        <text>⏱ {{countdown}}</text>
      </view>
    </view>

    <view class="action-btn-wrapper">
      <button
        class="action-btn fertilize-btn {{fertilizeCount <= 0 ? 'disabled' : ''}}"
        disabled="{{fertilizeCount <= 0}}"
        bindtap="onFertilize"
      >
        <text class="btn-icon">🌿</text>
        <text class="btn-text">施肥</text>
      </button>
      <view class="count-display">{{fertilizeCount}}</view>
    </view>
  </view>

  <!-- 恢复满预估时间 -->
  <view class="full-recover-info" wx:if="{{fullRecoverText}}">
    <text class="full-recover-text">💧 {{fullRecoverText}}</text>
  </view>

  <!-- 开发模式：无限浇水/施肥按钮 -->
  <view class="dev-actions" wx:if="{{isDev}}">
    <button class="dev-btn" bindtap="onDevWater">🔧 无限浇水</button>
    <button class="dev-btn" bindtap="onDevFertilize">🔧 无限施肥</button>
  </view>

  <!-- 升级弹窗 -->
  <view class="level-up-overlay" wx:if="{{showLevelUp}}" bindtap="onDismissLevelUp">
    <view class="level-up-dialog" catchtap="">
      <text class="level-up-title">🎉 升级成功！</text>
      <view class="level-up-levels">
        <text class="level-up-prev">Lv.{{levelUpInfo.prevLevel}}</text>
        <text class="level-up-arrow">→</text>
        <text class="level-up-cur">Lv.{{levelUpInfo.curLevel}}</text>
      </view>
      <view class="level-up-details">
        <text class="level-up-detail-item">成长值：{{levelUpInfo.growScore}}</text>
        <block wx:if="{{levelUpInfo.participating}}">
          <text class="level-up-detail-item">好友排名：第{{levelUpInfo.friendsRank}}名</text>
          <text class="level-up-detail-item">总排名：第{{levelUpInfo.allRank}}名</text>
        </block>
        <text class="level-up-detail-item level-up-hint" wx:else>参与排行，比比谁高！</text>
      </view>
      <button class="level-up-btn" bindtap="onDismissLevelUp">太棒了！</button>
    </view>
  </view>

  <!-- 卡牌获得通知（单次点击） -->
  <view class="card-notification" wx:if="{{cardGained}}" bindtap="onDismissCard">
    <view class="card-notification-content">
      <text class="card-notification-title">🎉 获得卡牌！</text>
      <view class="game-card-preview" style="background: {{cardGained._setBg}}; border-color: {{cardGained._setHue}};">
        <view class="game-card-preview-set" style="background: {{cardGained._setBg}}; border-color: {{cardGained._setHue}};">
          <text style="color: {{cardGained._setHue}};">{{cardGained._setName}}</text>
        </view>
        <view class="game-card-preview-name">{{cardGained.card_name}}</view>
        <view class="game-card-preview-stars stars-{{cardGained._starsCount}}">{{cardGained._stars}}</view>
      </view>
      <text class="card-notification-hint">点击关闭</text>
    </view>
  </view>

  <!-- 多张卡牌获得通知（长按结束后） -->
  <view class="card-notification" wx:if="{{cardsGained.length > 0}}" bindtap="onDismissCards">
    <view class="card-notification-content">
      <text class="card-notification-title">🎉 获得 {{cardsGained.length}} 张卡牌！</text>
      <view class="cards-gained-grid">
        <view class="game-card-preview game-card-preview-small" wx:for="{{cardsGained}}" wx:key="id" style="background: {{item._setBg}}; border-color: {{item._setHue}};">
          <view class="game-card-preview-set" style="background: {{item._setBg}}; border-color: {{item._setHue}};">
            <text style="color: {{item._setHue}};">{{item._setName}}</text>
          </view>
          <view class="game-card-preview-name">{{item.card_name}}</view>
          <view class="game-card-preview-stars stars-{{item._starsCount}}">{{item._stars}}</view>
        </view>
      </view>
      <text class="card-notification-hint">点击关闭</text>
    </view>
  </view>

  <!-- 集齐卡组提示 -->
  <view class="card-notification" wx:if="{{showSetComplete}}" bindtap="onDismissSetComplete">
    <view class="card-notification-content">
      <text class="card-notification-title">🏆 卡组集齐！</text>
      <text class="set-complete-name">{{setCompleteInfo.setName}}</text>
      <text class="set-complete-effect">{{setCompleteInfo.effectDescription}}</text>
      <text class="card-notification-hint">点击关闭</text>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
