<!--pages/index/index.wxml-->
<view class="page-container" wx:if="{{!loading}}">
  <!-- 树展示区域 -->
  <view class="tree-area">
    <view class="tree-icon">{{speciesIcon}}</view>
    <view class="tree-info">
      <text class="tree-name">{{speciesName}}</text>
      <text class="tree-level">Lv.{{level}}</text>
    </view>
  </view>

  <!-- 属性进度条 -->
  <view class="stats-area">
    <view class="stat-item">
      <view class="stat-label">
        <text class="stat-icon">🌱</text>
        <text>成长值</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill grow" style="width: {{growScore > 0 ? (growScore / 5500 * 100 > 100 ? 100 : growScore / 5500 * 100) : 0}}%"></view>
      </view>
      <text class="stat-value">{{growScore}}</text>
    </view>

    <view class="stat-item">
      <view class="stat-label">
        <text class="stat-icon">❤️</text>
        <text>健康值</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill health" style="width: {{healthScore}}%"></view>
      </view>
      <text class="stat-value">{{healthScore}}/100</text>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-area">
    <view class="action-btn-wrapper">
      <button
        class="action-btn water-btn {{waterCount <= 0 ? 'disabled' : ''}}"
        disabled="{{waterCount <= 0}}"
        bindtap="onWater"
      >
        <text class="btn-icon">💧</text>
        <text class="btn-text">浇水</text>
      </button>
      <view class="badge" wx:if="{{waterCount > 0}}">{{waterCount}}</view>
      <view class="countdown" wx:if="{{waterCount <= 0 && countdown}}">
        <text>{{countdown}}</text>
      </view>
    </view>

    <view class="action-btn-wrapper">
      <button
        class="action-btn fertilize-btn {{fertilizeCount <= 0 ? 'disabled' : ''}}"
        disabled="{{fertilizeCount <= 0}}"
        bindtap="onFertilize"
      >
        <text class="btn-icon">🌿</text>
        <text class="btn-text">施肥</text>
      </button>
      <view class="badge" wx:if="{{fertilizeCount > 0}}">{{fertilizeCount}}</view>
    </view>
  </view>

  <!-- 卡牌获得通知 -->
  <view class="card-notification" wx:if="{{cardGained}}" bindtap="onDismissCard">
    <view class="card-notification-content">
      <text class="card-notification-title">🎉 获得卡牌！</text>
      <text class="card-notification-name">{{cardGained.card_name}}</text>
      <text class="card-notification-quality">品质：{{cardGained.card_quality}}</text>
      <text class="card-notification-hint">点击关闭</text>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
