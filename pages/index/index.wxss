/* pages/index/index.wxss */
page {
  height: 100vh;
  background: linear-gradient(180deg, #e8f5e9 0%, #c8e6c9 50%, #a5d6a7 100%);
}

.page-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 树展示区域 */
.tree-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.tree-icon {
  font-size: 160rpx;
  margin-bottom: 20rpx;
  animation: treeSway 3s ease-in-out infinite;
}

@keyframes treeSway {
  0%, 100% { transform: rotate(-2deg); }
  50% { transform: rotate(2deg); }
}

.tree-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tree-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #2e7d32;
  margin-bottom: 8rpx;
}

.tree-level {
  font-size: 28rpx;
  color: #558b2f;
  background: rgba(255, 255, 255, 0.7);
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}

/* 属性进度条区域 */
.stats-area {
  width: 100%;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.stat-item:last-child {
  margin-bottom: 0;
}

.stat-label {
  display: flex;
  align-items: center;
  width: 160rpx;
  font-size: 26rpx;
  color: #424242;
}

.stat-icon {
  margin-right: 8rpx;
}

.progress-bar {
  flex: 1;
  height: 20rpx;
  background: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.progress-fill.grow {
  background: linear-gradient(90deg, #66bb6a, #43a047);
}

.progress-fill.health {
  background: linear-gradient(90deg, #ef5350, #e53935);
}

.stat-value {
  font-size: 24rpx;
  color: #757575;
  width: 120rpx;
  text-align: right;
}

/* 操作按钮区域 */
.action-area {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  width: 100%;
}

.action-btn-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.action-btn::after {
  border: none;
}

.water-btn {
  background: linear-gradient(135deg, #42a5f5, #1e88e5);
  color: #fff;
}

.fertilize-btn {
  background: linear-gradient(135deg, #66bb6a, #43a047);
  color: #fff;
}

.action-btn.disabled {
  background: #bdbdbd;
  box-shadow: none;
  opacity: 0.7;
}

.btn-icon {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.btn-text {
  font-size: 24rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #f44336;
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 8rpx;
}

.countdown {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #f57c00;
  background: rgba(255, 255, 255, 0.8);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

/* ========== 浇水飘字动画 ========== */
.water-float {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
  animation: floatUp 1s ease-out forwards;
  z-index: 10;
}

.water-float-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e88e5;
  white-space: nowrap;
}

@keyframes floatUp {
  0% {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-120rpx);
  }
}

/* ========== 升级弹窗 ========== */
.level-up-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.level-up-dialog {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: levelUpPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  min-width: 500rpx;
}

@keyframes levelUpPop {
  0% { transform: scale(0.3); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.level-up-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6f00;
  margin-bottom: 30rpx;
}

.level-up-levels {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.level-up-prev {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

.level-up-arrow {
  font-size: 36rpx;
  color: #4caf50;
  font-weight: bold;
}

.level-up-cur {
  font-size: 44rpx;
  color: #4caf50;
  font-weight: bold;
}

.level-up-details {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.level-up-detail-item {
  font-size: 28rpx;
  color: #555;
}

.level-up-hint {
  color: #999;
  font-style: italic;
}

.level-up-btn {
  background: linear-gradient(135deg, #66bb6a, #43a047);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 60rpx;
}

.level-up-btn::after {
  border: none;
}

/* ========== 卡牌获得通知 ========== */
.card-notification {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.card-notification-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: cardPopIn 0.3s ease;
}

@keyframes cardPopIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.card-notification-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6f00;
  margin-bottom: 20rpx;
}

.card-notification-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.card-notification-quality {
  font-size: 26rpx;
  color: #757575;
  margin-bottom: 20rpx;
}

.card-notification-hint {
  font-size: 22rpx;
  color: #bdbdbd;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 30rpx;
  color: #757575;
}
