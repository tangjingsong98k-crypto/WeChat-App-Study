<!--pages/select-tree/select-tree.wxml-->
<view class="page">
  <view class="title">选择你的树种</view>
  <view class="subtitle">选择一种树开始你的种树之旅</view>

  <view class="species-list">
    <view
      class="species-card {{selectedSpecies === item.id ? 'selected' : ''}}"
      wx:for="{{speciesList}}"
      wx:key="id"
      bindtap="onSelectSpecies"
      data-species="{{item.id}}"
    >
      <view class="species-icon">{{item.icon}}</view>
      <view class="species-name">{{item.name}}</view>
      <view class="species-desc">{{item.desc}}</view>
    </view>
  </view>

  <button
    class="confirm-btn"
    disabled="{{!selectedSpecies || loading}}"
    loading="{{loading}}"
    bindtap="onConfirm"
  >
    确认选择
  </button>
</view>
