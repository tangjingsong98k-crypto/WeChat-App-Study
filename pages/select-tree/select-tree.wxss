/* pages/select-tree/select-tree.wxss */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #ffffff 100%);
  box-sizing: border-box;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2e7d32;
  margin-top: 40rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  margin-bottom: 60rpx;
}

.species-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.species-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.species-card.selected {
  border-color: #4caf50;
  background: #f1f8e9;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.2);
}

.species-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.species-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.species-desc {
  font-size: 26rpx;
  color: #888;
}

.confirm-btn {
  margin-top: 60rpx;
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.confirm-btn[disabled] {
  background: #c8e6c9;
  color: #a5d6a7;
}
